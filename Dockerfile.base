FROM debian:latest

RUN apt-get update && apt-get upgrade -y && apt-get install -y \
    build-essential \
    curl \
    gh \
    git \
    htop \
    locales \
    net-tools \
    netcat-openbsd \
    openssh-server \
    python3 \
    python3-pip \
    python3-venv \
    sudo \
    vim \
    wget

# Generate locale to prevent setlocale warnings from SSH clients
RUN sed -i 's/# en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen && locale-gen

# Create "me" user with sudo access
RUN useradd -m -s /bin/bash me && \
    echo "me ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Configure SSH
COPY sshd_cm.conf /etc/ssh/sshd_config.d/cm.conf
RUN mkdir -p /var/run/sshd
RUN rm -f /etc/motd

# Setup SSH directory for me user
RUN mkdir -p /home/me/.ssh && \
    chmod 700 /home/me/.ssh && \
    chown me:me /home/me/.ssh

USER root
